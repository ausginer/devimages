{
  "name": "ai-service-image",
  "image": "node:25-bookworm-slim",
  "workspaceFolder": "/workspace",
  "remoteUser": "node",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1"
  },
  "remoteEnv": {
    "CARGO_HOME": "/home/node/.cargo",
    "PATH": "/home/node/.cargo/bin:${containerEnv:PATH}",
    "UV_CACHE_DIR": "/tmp/uv-cache"
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "node",
      "userUid": "automatic",
      "userGid": "automatic",
      "installZsh": false,
      "installOhMyZsh": false,
      "installOhMyZshConfig": false
    },
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    },
    "ghcr.io/va-h/devcontainers-features/uv:1": {},
    "ghcr.io/rails/devcontainer/features/postgres-client:1": {},
    "ghcr.io/kreemer/features/chrometesting:1": {
      "version": "Stable"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "./features/cargo-tools": {}
  }
}
